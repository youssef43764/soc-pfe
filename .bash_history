# Voir tous les types d'alertes distinctes
python3 -c "
import json
from collections import Counter

with open('/var/ossec/logs/alerts/alerts.json') as f:
    lines = f.readlines()

rules = Counter()
for line in lines:
    try:
        a = json.loads(line)
        desc = a.get('rule', {}).get('description', 'unknown')
        rules[desc] += 1
    except:
        pass

print('Top 20 alertes :')
for desc, count in rules.most_common(20):
    print('  {:4d} x {}'.format(count, desc))
"
python3 -c "
import json
from collections import Counter

with open('/var/ossec/logs/alerts/alerts.json') as f:
    lines = f.readlines()

rules = Counter()
for line in lines:
    try:
        a = json.loads(line)
        desc = a.get('rule', {}).get('description', 'unknown')
        rules[desc] += 1
    except:
        pass

print('Top 20 alertes :')
for desc, count in rules.most_common(20):
    print('  {:4d} x {}'.format(count, desc))
"
